binds {
    Mod+Tab{spawn-sh "sh ~/.config/niri/scripts/project-wofi.sh";}
    Mod+A  { spawn "bemoji";}
    Mod+Y { spawn-sh "alacritty --title Helix --command hx" ;}
    Mod+Z  { spawn-sh "~/.config/niri/colorswitcher.sh";}
    Mod+E  { spawn-sh "wezterm -e yazi";}
    Mod+Space   { spawn "firefox";}
    Mod+T  { spawn "foot";}
    Mod+D  { spawn-sh "fuzzel --hide-before-typing --lines 1";}
    Mod+Alt+L  { spawn "swaylock";}
    Mod+ampersand { spawn-sh "chromium --app=https://web.whatsapp.com";}
    Mod+2 { spawn-sh "chromium --app=https://music.youtube.com";}
    Mod+quotedbl{ spawn-sh "chromium --app=https://drive.google.com";}
    Mod+apostrophe{ spawn-sh "chromium --app=https://devdocs.io";}
    Mod+parenleft{ spawn-sh "chromium --app=https://youtube.com";}
    //minus
    //egrave
    //underscore
    //ccedilla
}
