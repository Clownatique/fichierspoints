set selection-clipboard wl-clipboard
map <C-o> feedkeys ":exec okular $FILE"
map o feedkeys ":open"
map <C-b> feedkeys "toggle_statusbar"
set default-bg "rgba(0, 0, 0, 0)"
set recolor-lightcolor "#e4b3e4" ##bg
set recolor-darkcolor "#0a1829" ## bg-fg
set render-loading-bg "rgba(0, 0, 0, 0)"

set statusbar-bg "#ff0000"
set statusbar-fg "#ff0000"

set completion-bg "#d57bd5"
set completion-fg "#000000"
set completion-highlight-bg "#fff1c9"
set completion-highlight-fg "#383838"

set inputbar-bg "#b5e6d1"
set inputbar-fg "#8ec07c"

set recolor-keephue true
set recolor true

### OPTIONS ###
set statusbar-home-tilde true
set window-title-basename true
set guioptions none
set synctex true
set selection-clipboard clipboard

set render-loading true
set page-cache-size 15
